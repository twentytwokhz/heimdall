{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning"
      }
    }
  },
  "Heimdall": {
    "ConfigLoader": "XmlOpenApi",
    "ConfigPath": "/config",
    "EnableAdminApi": false,
    "EnableConsole": true
  },
  "Backend": {
    "DefaultUrl": "http://localhost:8081"
  }
}
