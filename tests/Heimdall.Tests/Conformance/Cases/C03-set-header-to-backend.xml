<case name="inbound set-header reaches the backend">
  <policies>
    <inbound>
      <set-header name="X-Heimdall">
        <value>injected</value>
      </set-header>
    </inbound>
  </policies>
  <backend status="200" body="ok" />
  <request method="GET" path="/catalog/items" />
  <expect status="200">
    <backend-header name="X-Heimdall" contains="injected" />
  </expect>
</case>
