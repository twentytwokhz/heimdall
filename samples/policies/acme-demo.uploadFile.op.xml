<policies>
  <inbound>
    <base />
    <return-response>
      <set-status code="202" />
      <set-header name="Content-Type" exists-action="override">
        <value>application/json</value>
      </set-header>
      <set-header name="X-Upload-Echo" exists-action="override">
        <value>received</value>
      </set-header>
      <set-body>{"status":"accepted"}</set-body>
    </return-response>
  </inbound>
  <backend>
    <base />
  </backend>
  <outbound>
    <base />
  </outbound>
  <on-error>
    <base />
  </on-error>
</policies>
